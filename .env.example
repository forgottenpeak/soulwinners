# SoulWinners Environment Configuration

# Helius API (Required)
HELIUS_API_KEY=your_helius_api_key_here

# Telegram Bot (Required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1234567890

# Optional: Override default thresholds
# MIN_SOL_BALANCE=40
# MIN_TRADES_30D=20
# MIN_WIN_RATE=0.70
# MIN_ROI=0.70

# OpenClaw Auto-Trader (Optional)
# OPENCLAW_PRIVATE_KEY=your_solana_wallet_private_key
# OPENCLAW_CHAT_ID=your_telegram_chat_id_for_trade_alerts

# Wallet Encryption (Required for multi-user wallets)
# WALLET_ENCRYPTION_KEY=generate_with_Fernet.generate_key()

# Fee Collection (Optional)
# TREASURY_PRIVATE_KEY=treasury_wallet_private_key_for_fee_transfers

# AI Strategy Advisor (Required for AI reports)
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key
